generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  exp                 Int                  @default(0)
  gold                Int                  @default(50)
  level               Int                  @default(1)
  maxExp              Int                  @default(1000)
  playerClass         String               @default("Novice Scholar")
  expHistory          ExpHistory[]
  financeCategories   FinanceCategory[]
  financeTransactions FinanceTransaction[]
  productivityItems   ProductivityItem[]
  readingBooks        ReadingBook[]
  learningCourses     UserCourse[]
  learningProgresses  UserModuleProgress[]
  notes               WorkspaceNote[]
  dailyPerformances   DailyPerformance[]
}

model FinanceTransaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Float
  name      String
  category  String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinanceCategory {
  id        String   @id @default(uuid())
  userId    String
  type      String
  name      String
  icon      String
  color     String
  bg        String
  border    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductivityItem {
  id            String           @id @default(uuid())
  userId        String
  type          ProductivityType
  title         String
  isCompleted   Boolean          @default(false)
  status        String           @default("PENDING")
  dueDate       DateTime?
  day           String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lastCompleted DateTime?
  streak        Int              @default(0)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceNote {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingBook {
  id             String   @id @default(uuid())
  userId         String
  title          String
  author         String
  totalPages     Int      @default(0)
  readPages      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  currentChapter String?
  status         String   @default("PLAN_TO_READ")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id            String         @id @default(uuid())
  title         String
  description   String?
  thumbnail     String?
  totalDuration String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  modules       CourseModule[]
  enrollments   UserCourse[]
}

model CourseModule {
  id         String               @id @default(uuid())
  courseId   String
  title      String
  duration   String
  orderIndex Int
  contentMd  String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  course     Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses UserModuleProgress[]
}

model UserCourse {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  progressPercent Float    @default(0.0)
  status          String   @default("LEARNING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model UserModuleProgress {
  id          String       @id @default(uuid())
  userId      String
  moduleId    String
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model ExpHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProductivityType {
  TODO
  WEEKLY
  HABIT
}

model DailyPerformance {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime // Start of the day
  status          String   // "GREEN", "YELLOW", "ORANGE", "RED", "NONE"
  completedTasks  Int      @default(0)
  failedTasks     Int      @default(0)
  failedHabits    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
